# ============================================
# TariffGuard AI - Backend Environment Variables
# ============================================

# ============================================
# Required Configuration
# ============================================

# Google Gemini API Key (Required for AI agents)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL
# SQLite (default for development):
DATABASE_URL=sqlite+aiosqlite:///./tariffguard.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tariffguard

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# ============================================
# Optional Configuration
# ============================================

# Serper API Key (Optional - for enhanced web search)
# Get your key from: https://serper.dev/
SERPER_API_KEY=

# World Customs Organization API Key (Optional)
# Contact WCO for access: https://www.wcoomd.org/
WCO_API_KEY=

# Redis URL (Optional - for caching and session management)
# Local Redis:
# REDIS_URL=redis://localhost:6379
# Redis Cloud:
# REDIS_URL=redis://username:password@host:port
REDIS_URL=

# ============================================
# Application Settings (Optional)
# ============================================

# Application Name
APP_NAME=TariffGuard AI

# Debug Mode (set to false in production)
DEBUG=true

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# Security Settings (Optional)
# ============================================

# Secret Key for JWT tokens (generate a secure random string)
# SECRET_KEY=your-secret-key-here

# JWT Token Expiration (in minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# API Rate Limiting (Optional)
# ============================================

# Maximum requests per minute
# RATE_LIMIT_PER_MINUTE=60

# ============================================
# External Services (Optional)
# ============================================

# Email Service (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ============================================
# Notes
# ============================================
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to version control
# 3. Keep your API keys secure and rotate them regularly
# 4. Use different .env files for development, staging, and production